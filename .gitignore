# ============================================================
# LeadFlow AI CRM — .gitignore
# ============================================================

# === Environment & Secrets ===
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
secrets/

# === Node / npm ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock

# === Build Outputs ===
dist/
build/
out/
.next/
.nuxt/
.vite/

# === IDE & Editor ===
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# === OS Generated ===
.DS_Store
Thumbs.db
desktop.ini

# === Logs ===
logs/
*.log

# === Testing ===
coverage/
.nyc_output/

# === Cache ===
.cache/
.eslintcache
.stylelintcache
